{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pearl Marketing OS Spoke Manifest",
  "description": "Schema for validating spoke.yaml manifest files in the Pearl Marketing OS architecture",
  "type": "object",
  "required": ["name", "display_name", "version", "description", "aliases", "capabilities", "invoke"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Unique spoke identifier in kebab-case"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable name for conversation and docs"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "One-line description of the spoke's purpose"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Casual names the Director uses to match user requests to this spoke"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "minProperties": 1,
        "maxProperties": 1,
        "additionalProperties": { "type": "string" }
      },
      "minItems": 1,
      "description": "Named actions this spoke can perform, each with a description"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "minProperties": 1,
        "maxProperties": 1,
        "additionalProperties": { "type": "string" }
      },
      "description": "Named inputs this spoke accepts"
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "minProperties": 1,
        "maxProperties": 1,
        "additionalProperties": { "type": "string" }
      },
      "description": "Named outputs this spoke returns"
    },
    "shared_services": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["claude_api", "brand_context", "canva", "google_workspace", "asset_storage"]
      },
      "description": "Shared services this spoke requires"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Other spoke names this spoke depends on (invoked via Director)"
    },
    "invoke": {
      "type": "object",
      "required": ["cli", "library"],
      "properties": {
        "cli": {
          "type": "string",
          "minLength": 1,
          "description": "Shell command to invoke this spoke"
        },
        "library": {
          "type": "string",
          "minLength": 1,
          "description": "JavaScript/TypeScript import statement for programmatic use"
        }
      },
      "additionalProperties": false,
      "description": "How to invoke this spoke via CLI or as a library"
    }
  },
  "additionalProperties": false
}
